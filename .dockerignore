# ==============================================================================
# Docker Ignore File
# Purpose: Reduce Docker build context size and prevent sensitive data leakage
# ==============================================================================

# ------------------------------------------------------------------------------
# Git Metadata
# ------------------------------------------------------------------------------
# Exclude Git history and metadata to reduce build context size
.git
.gitignore


# ------------------------------------------------------------------------------
# Documentation Files
# ------------------------------------------------------------------------------
# Exclude non-essential files from image (optional for runtime)
# NOTE: Include these if your container needs them (e.g., for help endpoints)
README.md
LICENSE


# ------------------------------------------------------------------------------
# Unused / Non-Required Source Modules
# ------------------------------------------------------------------------------
# Exclude directories not required for the container runtime
src/spark
src/sql
unused/


# ------------------------------------------------------------------------------
# Runtime Data (Should Not Be Baked Into Image)
# ------------------------------------------------------------------------------
# Logs and checkpoints are environment-specific and should be mounted instead
logs/
checkpoints/


# ------------------------------------------------------------------------------
# Secrets & Environment Files (CRITICAL)
# ------------------------------------------------------------------------------
# Prevent accidental inclusion of sensitive credentials in image layers
# These should be injected at runtime (e.g., via volumes or environment variables)
secrets/
.env


# ------------------------------------------------------------------------------
# Python Cache Files
# ------------------------------------------------------------------------------
# Exclude compiled bytecode and cache directories
__pycache__/
*.pyc
*.pyo
*.pyd


# ------------------------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------------------------
# Local environments should not be copied into Docker images
# Dependencies should be installed via requirements.txt
venv/
.env/


# ------------------------------------------------------------------------------
# OS-Specific Junk Files
# ------------------------------------------------------------------------------
# Remove unnecessary files generated by operating systems
.DS_Store      # macOS
Thumbs.db      # Windows