# ==============================================================================
# Python Project .gitignore
# Purpose: Exclude generated files, secrets, environments, and build artifacts
# ==============================================================================


# ------------------------------------------------------------------------------
# Byte-Compiled / Interpreter Cache
# ------------------------------------------------------------------------------
# Python-generated cache files (not needed in version control)
__pycache__/
*.py[codz]
*$py.class


# ------------------------------------------------------------------------------
# Compiled Extensions
# ------------------------------------------------------------------------------
# Native compiled modules
*.so


# ------------------------------------------------------------------------------
# Logs & Runtime Output
# ------------------------------------------------------------------------------
# Application logs and runtime artifacts
logs/


# ------------------------------------------------------------------------------
# Data Files
# ------------------------------------------------------------------------------
# Local datasets or generated data (should not be versioned)
data/


# ------------------------------------------------------------------------------
# Spark / Streaming Checkpoints
# ------------------------------------------------------------------------------
# Temporary state for streaming frameworks (e.g., Spark, Kafka consumers)
tmp/
checkpoints/


# ------------------------------------------------------------------------------
# Secrets & Sensitive Data (CRITICAL)
# ------------------------------------------------------------------------------
# Never commit credentials, keys, or certificates
secrets/


# ------------------------------------------------------------------------------
# Distribution / Packaging Artifacts
# ------------------------------------------------------------------------------
# Files generated during packaging or installation
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST


# ------------------------------------------------------------------------------
# PyInstaller Artifacts
# ------------------------------------------------------------------------------
# Build-time metadata used when creating executables
*.manifest
*.spec


# ------------------------------------------------------------------------------
# Installer Logs
# ------------------------------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt


# ------------------------------------------------------------------------------
# Testing / Coverage Reports
# ------------------------------------------------------------------------------
# Output from test frameworks and coverage tools
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/


# ------------------------------------------------------------------------------
# Localization / Translation Files
# ------------------------------------------------------------------------------
*.mo
*.pot


# ------------------------------------------------------------------------------
# Build Systems
# ------------------------------------------------------------------------------
# PyBuilder and similar tools
.pybuilder/
target/


# ------------------------------------------------------------------------------
# Dependency Managers & Environment Tools
# ------------------------------------------------------------------------------
# These are usually environment-specific and should not be committed

# pipenv
#Pipfile.lock

# uv
#uv.lock

# poetry
#poetry.lock
#poetry.toml

# pdm
.pdm-python
.pdm-build/

# pixi
.pixi

# PEP 582
__pypackages__/


# ------------------------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------------------------
# Local Python environments (should be recreated via dependency files)
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/


# ------------------------------------------------------------------------------
# IDE / Editor Configurations
# ------------------------------------------------------------------------------
# VS Code
.vscode/


# ------------------------------------------------------------------------------
# Static Site Generators
# ------------------------------------------------------------------------------
# mkdocs output
/site


# ------------------------------------------------------------------------------
# Type Checkers & Static Analysis
# ------------------------------------------------------------------------------
# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# pytype
.pytype/


# ------------------------------------------------------------------------------
# Cython Debug
# ------------------------------------------------------------------------------
cython_debug/


# ------------------------------------------------------------------------------
# PyPI Configuration
# ------------------------------------------------------------------------------
# Contains credentials → should not be committed
.pypirc